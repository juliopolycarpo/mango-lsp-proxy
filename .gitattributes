# Normalize line endings on checkin; check out with LF everywhere.
* text=auto eol=lf

# Source / config: force LF.
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.toml      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.sh        text eol=lf

# Windows-only scripts keep CRLF.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary assets: never normalize.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.tgz       binary
*.wasm      binary

# Bun lockfile: treat as text but never let merge drivers mangle it.
bun.lock    text eol=lf -diff
bun.lockb   binary

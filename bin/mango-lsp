#!/usr/bin/env node
import { spawnSync } from "node:child_process";
import { existsSync } from "node:fs";
import { createRequire } from "node:module";
import { dirname, join } from "node:path";
import { fileURLToPath } from "node:url";

const targets = [
  {
    id: "windows-x64",
    platform: "win32",
    arch: "x64",
    packageName: "@mango-lsp/mango-lsp-proxy-windows-x64",
    binary: join("bin", "mango-lsp.exe"),
  },
  {
    id: "windows-arm64",
    platform: "win32",
    arch: "arm64",
    packageName: "@mango-lsp/mango-lsp-proxy-windows-arm64",
    binary: join("bin", "mango-lsp.exe"),
  },
  {
    id: "linux-x64",
    platform: "linux",
    arch: "x64",
    libc: "glibc",
    packageName: "@mango-lsp/mango-lsp-proxy-linux-x64",
    binary: join("bin", "mango-lsp"),
  },
  {
    id: "linux-arm64",
    platform: "linux",
    arch: "arm64",
    libc: "glibc",
    packageName: "@mango-lsp/mango-lsp-proxy-linux-arm64",
    binary: join("bin", "mango-lsp"),
  },
  {
    id: "linux-x64-musl",
    platform: "linux",
    arch: "x64",
    libc: "musl",
    packageName: "@mango-lsp/mango-lsp-proxy-linux-x64-musl",
    binary: join("bin", "mango-lsp"),
  },
  {
    id: "linux-arm64-musl",
    platform: "linux",
    arch: "arm64",
    libc: "musl",
    packageName: "@mango-lsp/mango-lsp-proxy-linux-arm64-musl",
    binary: join("bin", "mango-lsp"),
  },
];

const require = createRequire(import.meta.url);
const launcherDir = dirname(fileURLToPath(import.meta.url));

function linuxLibc() {
  if (process.platform !== "linux") return undefined;
  const report = process.report?.getReport?.();
  const header = report?.header ?? {};
  return typeof header.glibcVersionRuntime === "string" ||
    typeof header.glibcVersionCompiler === "string"
    ? "glibc"
    : "musl";
}

function targetForHost() {
  const forced = process.env.MANGO_LSP_NATIVE_TARGET;
  if (forced !== undefined) return targets.find((target) => target.id === forced);

  const libc = linuxLibc();
  return targets.find(
    (target) =>
      target.platform === process.platform &&
      target.arch === process.arch &&
      (target.platform !== "linux" || target.libc === libc),
  );
}

function packageBinary(target) {
  try {
    const packageJson = require.resolve(`${target.packageName}/package.json`);
    return join(dirname(packageJson), target.binary);
  } catch {
    return undefined;
  }
}

function localBinary(target) {
  return join(launcherDir, "..", "packages", "native", target.id, target.binary);
}

const overrideBinary = process.env.MANGO_LSP_NATIVE_PATH;
const target = targetForHost();
const binary =
  overrideBinary ??
  (target === undefined
    ? undefined
    : [packageBinary(target), localBinary(target)].find(
        (candidate) => candidate !== undefined && existsSync(candidate),
      ));

if (target === undefined && overrideBinary === undefined) {
  console.error(
    `mango-lsp: unsupported platform ${process.platform}/${process.arch}${
      process.platform === "linux" ? `/${linuxLibc() ?? "unknown-libc"}` : ""
    }`,
  );
  process.exit(1);
}

if (binary === undefined || !existsSync(binary)) {
  const targetName = target?.id ?? "override";
  console.error(`mango-lsp: native binary for ${targetName} was not installed`);
  console.error("mango-lsp: reinstall mango-lsp-proxy without omitting optional dependencies");
  process.exit(1);
}

const result = spawnSync(binary, process.argv.slice(2), { stdio: "inherit" });
if (result.error !== undefined) {
  console.error(`mango-lsp: failed to run ${binary}: ${result.error.message}`);
  process.exit(1);
}
if (result.signal !== null) {
  process.kill(process.pid, result.signal);
}
process.exit(result.status ?? 1);
